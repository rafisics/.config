{
  "name": "literature",
  "version": "2.0.0",
  "description": "Unified literature management: scan, convert PDFs/DJVUs, maintain index.json, search/import from Zotero, and manage per-repo sub-index. Replaces separate zotero extension.",
  "dependencies": [
    "core",
    "filetypes"
  ],
  "routing_exempt": true,
  "provides": {
    "agents": [
      "literature-agent.md"
    ],
    "commands": [
      "literature.md",
      "cite.md"
    ],
    "skills": [
      "skill-literature",
      "skill-cite"
    ],
    "scripts": [
      "scripts/zotero-search.sh",
      "scripts/cite-extract.sh",
      "scripts/zotero-read.sh",
      "scripts/zotero-write.sh",
      "scripts/zotero-setup.sh",
      "scripts/zotero-chunk.sh",
      "scripts/zotero-attach-chunks.sh",
      "scripts/zotero-index-add.sh",
      "scripts/zotero-index-remove.sh",
      "scripts/zotero-retrieve.sh",
      "scripts/zotero-search-index.sh"
    ]
  },
  "merge_targets": {
    "claudemd": {
      "source": "EXTENSION.md",
      "target": ".claude/CLAUDE.md",
      "section_id": "extension_literature"
    },
    "index": {
      "source": "index-entries.json",
      "target": ".claude/context/index.json"
    }
  },
  "keyword_overrides": {
    "literature": "meta",
    "zotero": "meta",
    "bibliography": "meta",
    "citation": "meta"
  },
  "hooks": {}
}
